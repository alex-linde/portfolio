{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "gulpfile.js",
  "scripts": {
    "start": "concurrently \"npm run watch:css\" \"npm run watch:js\" \"npm run watch:jekyll\"",
    "stop": "pkill -f 'jekyll serve' 2>/dev/null; exit 0",
    "build": "npm run clean && npm-run-all --parallel build:css build:js build:images && npm run build:jekyll",
    "build:css": "sass _assets/styles/main.sass assets/styles/main.min.css --style=compressed --no-source-map && postcss assets/styles/main.min.css --use autoprefixer --replace",
    "build:js": "esbuild _assets/js/main.js --bundle --minify --outfile=assets/js/main.min.js",
    "build:images": "mkdir -p assets/img && cp -r _assets/img/. assets/img/",
    "build:jekyll": "jekyll build",
    "watch:css": "sass --watch _assets/styles/main.sass:assets/styles/main.min.css",
    "watch:js": "esbuild _assets/js/main.js --bundle --minify --outfile=assets/js/main.min.js --watch",
    "watch:jekyll": "jekyll serve --livereload --skip-initial-build",
    "dev": "npm run build && npm start",
    "clean": "del-cli _site assets/js assets/styles assets/img"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "del-cli": "^6.0.0",
    "esbuild": "^0.25.0",
    "npm-run-all": "^4.1.5",
    "postcss-cli": "^11.0.0",
    "sass": "^1.54.9"
  },
  "overrides": {
    "minimatch": "^3.1.5",
    "cross-spawn": "^7.0.6",
    "http-cache-semantics": "^4.2.0"
  },
  "browserslist": [
    "cover 99.5%"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alex-linde/portfolio.git"
  },
  "author": "Alex Linde",
  "license": "ISC"
}
